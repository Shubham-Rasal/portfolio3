---
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  author?: string;
  date?: string;
}

const { title, author, date } = Astro.props;

// import SpeedInsights from "@vercel/speed-insights/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Shubham Rasal - Reading List" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/code.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Shubham Rasal - Portfolio & Blog RSS Feed"
      href={new URL("rss.xml", Astro.site)}
    />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/preview.png" />
    <meta name="google-site-verification" content="xcfPLYm2QbAGmBNI4r4k6BEDQnTpTWgWtsltzZvl7cE" />
    <link rel="stylesheet" href="/globals.css" />
    <!-- <SpeedInsights /> -->
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body
    class="min-h-screen w-full mx-auto top-0 z-[-2] bg-[#f8f5f0] text-slate-900"
  >
    <div
      class="sticky top-0 z-10 w-full p-2 flex items-center h-16 justify-center bg-[#f8f5f0]/90 backdrop-blur border-b border-slate-200"
    >
      <nav class="text-slate-700 p-1 flex w-auto text-sm">
        <div class="p-2 font-semibold rounded-full mx-1">
          <a href="/">About</a>
        </div>
        <div class="flex dark:font-light font-normal">
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/projects">Projects</a>
          </div>
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/writing" class="">Writing</a>
          </div>
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/reading">Reading</a>
          </div>
        </div>
      </nav>
    </div>
    
    <main class="max-w-4xl mx-auto px-6 py-8">
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-slate-900 mb-2">{title}</h1>
        {author && (
          <p class="text-slate-600 text-lg">by {author}</p>
        )}
        {date && (
          <p class="text-slate-500 text-sm">{date}</p>
        )}
      </div>

      <div class="prose prose-slate prose-lg max-w-none">
        <style>
          /* Custom styles for reading list */
          .reading-category {
            margin-bottom: 2rem;
          }
          
          .category-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e2e8f0;
          }
          
          .reading-list {
            list-style: none;
            padding: 0;
            margin: 0;
          }
          
          .reading-item {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.2s ease;
          }
          
          .reading-item:hover {
            background-color: #f8fafc;
            border-color: #cbd5e1;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
          }
          
          .reading-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1rem;
          }
          
          .reading-main-content {
            flex: 1;
            margin-right: 1rem;
          }
          
          .reading-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 0.5rem;
            line-height: 1.4;
          }
          
          .reading-description {
            color: #4b5563;
            font-size: 0.95rem;
            line-height: 1.5;
            margin-bottom: 0.75rem;
          }
          
          .reading-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
          }
          
          .reading-link {
            display: inline-flex;
            align-items: center;
            padding: 0.375rem 0.75rem;
            background-color: #1d4ed8;
            color: #f8fafc;
            text-decoration: none;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s ease;
            border: 1px solid transparent;
          }
          
          .reading-link:hover {
            background-color: #1e40af;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(30, 64, 175, 0.2);
          }
          
          .reading-link.paper {
            background-color: #b91c1c;
          }
          
          .reading-link.paper:hover {
            background-color: #dc2626;
          }
          
          .reading-link.blog {
            background-color: #047857;
          }
          
          .reading-link.blog:hover {
            background-color: #059669;
          }
          
          .reading-link.video {
            background-color: #6d28d9;
          }
          
          .reading-link.video:hover {
            background-color: #7c3aed;
          }
          
          .reading-notes {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            padding: 1rem;
            margin-top: 0.75rem;
          }
          
          .reading-notes-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
          }
          
          .reading-notes-content {
            color: #4b5563;
            font-size: 0.875rem;
            line-height: 1.5;
          }
          
          .reading-status {
            display: inline-flex;
            align-items: center;
            font-size: 0.75rem;
            padding: 0.375rem 0.75rem;
            border-radius: 0.375rem;
            font-weight: 500;
            white-space: nowrap;
          }
          
          .status-unread {
            background-color: #e5e7eb;
            color: #6b7280;
            border: 1px solid #d1d5db;
          }
          
          .status-read {
            background-color: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
          }
          
          .status-in-progress {
            background-color: #fef3c7;
            color: #b45309;
            border: 1px solid #fde68a;
          }
          
          .status-skimmed {
            background-color: #dbeafe;
            color: #2563eb;
            border: 1px solid #bfdbfe;
          }
          
          .reading-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.75rem;
          }
          
          .reading-tag {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            background-color: rgba(29, 78, 216, 0.08);
            color: #1d4ed8;
            border: 1px solid rgba(29, 78, 216, 0.2);
            border-radius: 0.25rem;
            font-size: 0.75rem;
            font-weight: 500;
          }
          
          .reading-checkbox {
            margin-right: 0.75rem;
            margin-top: 0.25rem;
            width: 1.25rem;
            height: 1.25rem;
            accent-color: #1d4ed8;
            cursor: pointer;
          }
          
          @media (max-width: 768px) {
            .reading-header {
              flex-direction: column;
              align-items: flex-start;
            }
            
            .reading-status {
              margin-top: 0.75rem;
            }
            
            .reading-links {
              flex-direction: column;
            }
            
            .reading-link {
              justify-content: center;
            }
          }
        </style>
        
        <slot />
      </div>
    </main>
  </body>
</html>
