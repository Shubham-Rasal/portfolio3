---
import Layout from "./Layout.astro";

export interface Props {
  title: string;
  author?: string;
  date?: string;
  intro?: string;
}

const { title, author, date, intro } = Astro.props;
---

<Layout title={title}>
  <main class="max-w-2xl mx-auto px-5 sm:px-6 py-10 sm:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="font-serif text-2xl sm:text-[1.65rem] font-normal tracking-tight mb-2" style="color: var(--lw-text)">
        {title}
      </h1>
      {intro && (
        <p class="lw-sans text-sm leading-relaxed" style="color: var(--lw-muted)">
          {intro}
        </p>
      )}
      {(author || date) && (
        <p class="mt-3 text-xs lw-sans" style="color: var(--lw-muted)">
          {author && <span>by {author}</span>}
          {author && date && <span class="mx-1.5">·</span>}
          {date && <time datetime={date}>{date}</time>}
        </p>
      )}
    </header>

    <div class="reading-slot">
      <slot />
    </div>
  </main>
</Layout>
