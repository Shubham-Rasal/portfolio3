---
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  author?: string;
  date?: string;
  intro?: string;
}

const { title, author, date, intro } = Astro.props;

// import SpeedInsights from "@vercel/speed-insights/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Shubham Rasal - Reading List" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/code.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Shubham Rasal - Portfolio & Blog RSS Feed"
      href={new URL("rss.xml", Astro.site)}
    />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/preview.png" />
    <meta name="google-site-verification" content="xcfPLYm2QbAGmBNI4r4k6BEDQnTpTWgWtsltzZvl7cE" />
    <link rel="stylesheet" href="/globals.css" />
    <!-- <SpeedInsights /> -->
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body
    class="min-h-screen w-full mx-auto top-0 z-[-2] bg-[#f8f5f0] text-slate-900"
  >
    <div
      class="sticky top-0 z-10 w-full p-2 flex items-center h-16 justify-center bg-[#f8f5f0]/90 backdrop-blur border-b border-slate-200"
    >
      <nav class="text-slate-700 p-1 flex w-auto text-sm">
        <div class="p-2 font-semibold rounded-full mx-1">
          <a href="/">About</a>
        </div>
        <div class="flex dark:font-light font-normal">
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/projects">Projects</a>
          </div>
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/writing" class="">Writing</a>
          </div>
          <div
            class="p-2 items-center flex rounded-full mx-2 hover:text-slate-900 hover:underline"
          >
            <a href="/reading">Reading</a>
          </div>
        </div>
      </nav>
    </div>
    
    <main class="max-w-2xl mx-auto px-5 sm:px-6 py-10 sm:py-12">
      <header class="mb-8 sm:mb-10">
        <h1 class="font-serif text-2xl sm:text-[1.65rem] font-normal tracking-tight text-slate-900 mb-2">
          {title}
        </h1>
        {intro && (
          <p class="lw-sans text-sm text-slate-500 leading-relaxed">
            {intro}
          </p>
        )}
        {(author || date) && (
          <p class="mt-3 text-xs text-slate-400 lw-sans">
            {author && <span>by {author}</span>}
            {author && date && <span class="mx-1.5 text-slate-300">·</span>}
            {date && <time datetime={date}>{date}</time>}
          </p>
        )}
      </header>

      <div class="reading-slot">
        <slot />
      </div>
    </main>
  </body>
</html>
