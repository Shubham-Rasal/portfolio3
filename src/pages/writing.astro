---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";
import { extractExcerpt } from "../utils/excerpt";
import { formatDate } from "../utils/dateFormat";

// Get all entries from a collection.
// Requires the name of the collection as an argument.
// Example: retrieve `src/content/writing/**`
interface BlogPost {
  slug?: string;
  id?: string; // Optional for interactive blog posts
  body?: string; // Add body content for excerpts - optional as it might be undefined
  data: {
    title: string;
    date: Date;
    tags?: string[];
  };
}


const allBlogPosts: BlogPost[] = await getCollection("blog");
const allInteractiveBlogPosts: BlogPost[] = await getCollection("interactiveBlog");

const allPosts = [...allBlogPosts, ...allInteractiveBlogPosts];
allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Get selected tag from URL query parameter
const url = new URL(Astro.request.url);
const selectedTag = url.searchParams.get('tag');

// Filter posts by tag if a tag is selected
const filteredPosts = selectedTag 
  ? allPosts.filter(post => post.data.tags?.includes(selectedTag))
  : allPosts;

// Get all unique tags from all posts
const allTags = Array.from(
  new Set(
    allPosts.flatMap(post => post.data.tags || [])
  )
).sort();
---

<Layout title="Writing">
  <h1 class="text-2xl font-bold text-center my-4">Writing</h1>
  
  <!-- Tag Filter Section -->
  <div class="md:w-1/2 w-3/4 mx-auto mb-6">
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-sm font-semibold text-gray-400">Filter by tag:</span>
      <a 
        href="/writing" 
        class={`text-xs px-3 py-1 rounded-full transition-colors ${
          !selectedTag 
            ? 'bg-blue-500 text-white' 
            : 'bg-gray-700 text-gray-300 hover:bg-gray-600'
        }`}
      >
        All
      </a>
      {allTags.map(tag => (
        <a 
          href={`/writing?tag=${encodeURIComponent(tag)}`}
          class={`text-xs px-3 py-1 rounded-full transition-colors ${
            selectedTag === tag 
              ? 'bg-blue-500 text-white' 
              : 'bg-gray-700 text-gray-300 hover:bg-gray-600'
          }`}
        >
          {tag}
        </a>
      ))}
    </div>
    {selectedTag && (
      <div class="mt-3 text-sm text-gray-400">
        Showing {filteredPosts.length} post{filteredPosts.length !== 1 ? 's' : ''} tagged with "{selectedTag}"
      </div>
    )}
  </div>

  <main class="md:w-1/2 w-3/4 mx-auto justify-center">
    {
      filteredPosts.map((post) => (
        <article class="flex border-dashed font-medium w-full py-3 md:py-[8px] dark:text-white border-b border-gray-200 hover:border-gray-400 dark:border-gray-700 dark:hover:border-gray-500 flex-col text-gray-200">
          <a href={`/writing/${post.slug || post.id}`} class="no-underline">
            <div class="flex flex-col md:flex-row md:items-center">
              <h2 class="inline-flex text-gray-300 dark:text-gray-200">
                <span>{post.data.title}</span>
              </h2>
              <div class="md:pl-2 md:ml-auto font-normal opacity-60 dark:opacity-40">
                {formatDate(post.data.date)}
              </div>
            </div>
            <p class="text-gray-500 dark:text-gray-500 text-sm mt-2 leading-relaxed">
              {extractExcerpt(post.body || '', 120)}
            </p>
          </a>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-2">
              {post.data.tags.map((tag: string) => (
                <a
                  href={`/writing?tag=${encodeURIComponent(tag)}`}
                  class="tag-link text-xs px-2 py-0.5 bg-gray-800 text-gray-400 rounded hover:bg-gray-700 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </main>
</Layout>
