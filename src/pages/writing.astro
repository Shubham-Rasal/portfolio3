---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";
import { extractExcerpt } from "../utils/excerpt";
import { formatDate } from "../utils/dateFormat";

// Get all entries from a collection.
// Requires the name of the collection as an argument.
// Example: retrieve `src/content/writing/**`
interface BlogPost {
  slug?: string;
  id?: string; // Optional for interactive blog posts
  body?: string; // Add body content for excerpts - optional as it might be undefined
  data: {
    title: string;
    date: Date;
    tags?: string[];
  };
}


const allBlogPosts: BlogPost[] = await getCollection("blog");
const allInteractiveBlogPosts: BlogPost[] = await getCollection("interactiveBlog");

const allPosts = [...allBlogPosts, ...allInteractiveBlogPosts];
allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Get all unique tags from all posts
const allTags = Array.from(
  new Set(
    allPosts.flatMap(post => post.data.tags || [])
  )
).sort();
---

<Layout title="Writing">
  <h1 class="text-2xl font-bold text-center my-4">Writing</h1>
  
  <!-- Tag Filter Section -->
  <div class="md:w-1/2 w-3/4 mx-auto mb-6">
    <div class="flex flex-wrap gap-2 items-center">
      <span class="text-sm font-semibold text-gray-400">Filter by tag:</span>
      <button 
        data-tag=""
        class="tag-filter text-xs px-3 py-1 rounded-full transition-colors bg-blue-500 text-white"
      >
        All
      </button>
      {allTags.map(tag => (
        <button 
          data-tag={tag}
          class="tag-filter text-xs px-3 py-1 rounded-full transition-colors bg-gray-700 text-gray-300 hover:bg-gray-600"
        >
          {tag}
        </button>
      ))}
    </div>
    <div id="filter-status" class="mt-3 text-sm text-gray-400 hidden">
    </div>
  </div>

  <main class="md:w-1/2 w-3/4 mx-auto justify-center">
    {
      allPosts.map((post) => (
        <article 
          class="post-item flex border-dashed font-medium w-full py-3 md:py-[8px] dark:text-white border-b border-gray-200 hover:border-gray-400 dark:border-gray-700 dark:hover:border-gray-500 flex-col text-gray-200"
          data-tags={JSON.stringify(post.data.tags || [])}
        >
          <a href={`/writing/${post.slug || post.id}`} class="no-underline">
            <div class="flex flex-col md:flex-row md:items-center">
              <h2 class="inline-flex text-gray-300 dark:text-gray-200">
                <span>{post.data.title}</span>
              </h2>
              <div class="md:pl-2 md:ml-auto font-normal opacity-60 dark:opacity-40">
                {formatDate(post.data.date)}
              </div>
            </div>
            <p class="text-gray-500 dark:text-gray-500 text-sm mt-2 leading-relaxed">
              {extractExcerpt(post.body || '', 120)}
            </p>
          </a>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-2">
              {post.data.tags.map((tag: string) => (
                <button
                  data-tag={tag}
                  class="tag-filter text-xs px-2 py-0.5 bg-gray-800 text-gray-400 rounded hover:bg-gray-700 transition-colors cursor-pointer"
                >
                  {tag}
                </button>
              ))}
            </div>
          )}
        </article>
      ))
    }
  </main>
  
  <script>
    // Client-side filtering logic
    function updateFilter(selectedTag: string) {
      const posts = document.querySelectorAll('.post-item');
      const filterButtons = document.querySelectorAll('.tag-filter');
      const filterStatus = document.getElementById('filter-status');
      
      let visibleCount = 0;
      
      // Update post visibility
      posts.forEach((post) => {
        const postElement = post as HTMLElement;
        const tags = JSON.parse(postElement.dataset.tags || '[]');
        
        if (!selectedTag || tags.includes(selectedTag)) {
          postElement.style.display = 'flex';
          visibleCount++;
        } else {
          postElement.style.display = 'none';
        }
      });
      
      // Update button states (only for top filter buttons, not post tag buttons)
      const topFilterButtons = document.querySelectorAll('.md\\:w-1\\/2 .tag-filter');
      topFilterButtons.forEach((btn) => {
        const button = btn as HTMLButtonElement;
        const btnTag = button.dataset.tag || '';
        
        if (btnTag === selectedTag) {
          button.className = 'tag-filter text-xs px-3 py-1 rounded-full transition-colors bg-blue-500 text-white';
        } else {
          button.className = 'tag-filter text-xs px-3 py-1 rounded-full transition-colors bg-gray-700 text-gray-300 hover:bg-gray-600';
        }
      });
      
      // Update filter status message
      if (filterStatus) {
        if (selectedTag) {
          filterStatus.textContent = `Showing ${visibleCount} post${visibleCount !== 1 ? 's' : ''} tagged with "${selectedTag}"`;
          filterStatus.classList.remove('hidden');
        } else {
          filterStatus.classList.add('hidden');
        }
      }
      
      // Update URL without reload
      const url = new URL(window.location.href);
      if (selectedTag) {
        url.searchParams.set('tag', selectedTag);
      } else {
        url.searchParams.delete('tag');
      }
      window.history.pushState({}, '', url.toString());
    }
    
    // Initialize filter from URL on page load
    function initFilter() {
      const urlParams = new URLSearchParams(window.location.search);
      const tagFromUrl = urlParams.get('tag');
      if (tagFromUrl) {
        updateFilter(tagFromUrl);
      }
    }
    
    // Set up event listeners
    document.addEventListener('DOMContentLoaded', () => {
      initFilter();
      
      // Add click handlers to all filter buttons
      document.querySelectorAll('.tag-filter').forEach((button) => {
        button.addEventListener('click', (e) => {
          e.preventDefault();
          const btn = e.currentTarget as HTMLButtonElement;
          const tag = btn.dataset.tag || '';
          updateFilter(tag);
        });
      });
    });
    
    // Re-initialize on navigation (for Astro's client-side routing)
    document.addEventListener('astro:page-load', () => {
      initFilter();
      
      // Re-attach event listeners after page transition
      document.querySelectorAll('.tag-filter').forEach((button) => {
        button.addEventListener('click', (e) => {
          e.preventDefault();
          const btn = e.currentTarget as HTMLButtonElement;
          const tag = btn.dataset.tag || '';
          updateFilter(tag);
        });
      });
    });
  </script>
</Layout>
