---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";
import { extractExcerpt } from "../utils/excerpt";
import { formatDate } from "../utils/dateFormat";

interface BlogPost {
  slug?: string;
  id?: string;
  body?: string;
  data: {
    title: string;
    date: Date;
    tags?: string[];
  };
}

const allBlogPosts: BlogPost[] = await getCollection("blog");
const allInteractiveBlogPosts: BlogPost[] = await getCollection("interactiveBlog");

const allPosts = [...allBlogPosts, ...allInteractiveBlogPosts];
allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const allTags = Array.from(
  new Set(allPosts.flatMap((post) => post.data.tags || []))
).sort();
---

<Layout title="Writing">
  <main class="max-w-2xl mx-auto px-5 sm:px-6 py-10 sm:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="font-serif text-2xl sm:text-[1.65rem] font-normal tracking-tight mb-2" style="color: var(--lw-text)">
        Writing
      </h1>
      <p class="lw-sans text-sm leading-relaxed" style="color: var(--lw-muted)">
        Posts and notes, newest first.
      </p>
    </header>

    <div id="filter-section" class="mb-8">
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
        <span class="text-[11px] font-medium uppercase tracking-[0.16em] shrink-0" style="color: var(--lw-muted)">Tags</span>
        <div class="flex flex-wrap gap-x-3 gap-y-1">
          <button type="button" data-tag="" class="tag-filter tag-filter--nav lw-sans text-[13px] font-medium" style="color: var(--lw-text)">
            All
          </button>
          {allTags.map((tag) => (
            <button type="button" data-tag={tag} class="tag-filter tag-filter--nav lw-sans text-[13px] transition-colors" style="color: var(--lw-muted)">
              {tag}
            </button>
          ))}
        </div>
      </div>
      <div id="filter-status" class="mt-3 text-[13px] hidden" style="color: var(--lw-muted)" />
    </div>

    <ul class="border-t divide-y list-none p-0 m-0" style="border-color: var(--lw-border)">
      {
        allPosts.map((post) => (
          <li class="post-item py-3.5" data-tags={JSON.stringify(post.data.tags || [])} style="border-color: var(--lw-border)">
            <article>
              <a href={`/writing/${post.slug || post.id}`} class="block group no-underline text-inherit">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-6">
                  <div class="min-w-0 flex-1">
                    <h2 class="font-serif text-[1.05rem] sm:text-[1.08rem] font-normal leading-snug transition-colors" style="color: var(--lw-text)">
                      {post.data.title}
                    </h2>
                    <p class="mt-1 text-[13px] leading-relaxed" style="color: var(--lw-muted)">
                      {extractExcerpt(post.body || "", 120)}
                    </p>
                  </div>
                  <time class="lw-sans shrink-0 text-[13px] tabular-nums sm:pt-0.5" style="color: var(--lw-muted)" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                </div>
              </a>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                  {post.data.tags.map((tag: string) => (
                    <button type="button" data-tag={tag} class="tag-filter tag-filter--inline lw-sans cursor-pointer border-0 bg-transparent p-0 text-left text-[12px] transition-colors" style="color: var(--lw-muted)">
                      {tag}
                    </button>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))
      }
    </ul>
  </main>

  <script>
    const BASE_NAV = "tag-filter tag-filter--nav lw-sans text-[13px] transition-colors";
    const ACTIVE_NAV = `${BASE_NAV} font-medium text-slate-900`;
    const INACTIVE_NAV = `${BASE_NAV} text-slate-500 hover:text-slate-800`;

    function updateFilter(selectedTag: string) {
      const posts = document.querySelectorAll(".post-item");
      const filterStatus = document.getElementById("filter-status");

      let visibleCount = 0;

      posts.forEach((post) => {
        const postElement = post as HTMLElement;
        let tags: string[] = [];

        try {
          tags = JSON.parse(postElement.dataset.tags || "[]");
        } catch {
          tags = [];
        }

        if (!selectedTag || tags.includes(selectedTag)) {
          postElement.style.removeProperty("display");
          visibleCount++;
        } else {
          postElement.style.display = "none";
        }
      });

      const filterSection = document.getElementById("filter-section");
      if (filterSection) {
        const topFilterButtons =
          filterSection.querySelectorAll(".tag-filter--nav");
        topFilterButtons.forEach((btn) => {
          const button = btn as HTMLButtonElement;
          const btnTag = button.dataset.tag || "";
          button.className =
            btnTag === selectedTag ? ACTIVE_NAV : INACTIVE_NAV;
        });
      }

      if (filterStatus) {
        if (selectedTag) {
          filterStatus.textContent = `Showing ${visibleCount} post${visibleCount !== 1 ? "s" : ""} tagged "${selectedTag}"`;
          filterStatus.classList.remove("hidden");
        } else {
          filterStatus.classList.add("hidden");
        }
      }

      const url = new URL(window.location.href);
      if (selectedTag) {
        url.searchParams.set("tag", selectedTag);
      } else {
        url.searchParams.delete("tag");
      }
      window.history.pushState({}, "", url.toString());
    }

    function initFilter() {
      const urlParams = new URLSearchParams(window.location.search);
      const tagFromUrl = urlParams.get("tag");
      if (tagFromUrl) {
        updateFilter(tagFromUrl);
      }
    }

    function handleFilterClick(e: Event) {
      e.preventDefault();
      const btn = e.currentTarget as HTMLButtonElement;
      const tag = btn.dataset.tag || "";
      updateFilter(tag);
    }

    function attachEventListeners() {
      document.querySelectorAll(".tag-filter").forEach((button) => {
        button.removeEventListener("click", handleFilterClick);
        button.addEventListener("click", handleFilterClick);
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      initFilter();
      attachEventListeners();
    });

    document.addEventListener("astro:page-load", () => {
      initFilter();
      attachEventListeners();
    });
  </script>
</Layout>
