---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { render } from "astro:content";
import { getEntry } from "astro:content";
import { formatDateMedium } from "../../utils/dateFormat";
import Sidenote from "../../content/components/Sidenote.tsx";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  const interactiveBlogEntries = await getCollection("interactiveBlog");
  const blogEntriesWithId = blogEntries.filter((entry) => entry.id);
  const interactiveBlogEntriesWithId = interactiveBlogEntries.filter(
    (entry) => entry.id
  );
  const allEntries = [...blogEntriesWithId, ...interactiveBlogEntriesWithId];
  allEntries.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return allEntries.map((entry) => ({
    // Use the entry id to create the path
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
const post = await getEntry(entry.collection, entry.id);
if (post === undefined) {
  return Astro.redirect("/404");
}
const { Content } = await render(post);

// Construct the OG image URL for this blog post
const ogImageUrl = new URL(`/open-graph/writing/${entry.id}.png`, Astro.site).href;

---

<Layout title={entry.data.title} ogImage={ogImageUrl}>
  <article
    class="px-6 sm:px-6 py-2 sm:py-16 lg:py-12 mx-auto max-w-6xl text-lg text-slate-800"
  >
    <button class="my-8 py-8 flex text-slate-600 hover:text-slate-900">
      <a href="/writing" class="text-inherit"> &larr; Back to writing</a>
    </button>
    <div
      class="mx-auto sm:px-6 max-w-3xl prose prose-slate prose-lg prose-headings:text-slate-900 prose-headings:font-semibold prose-headings:leading-tight prose-headings:tracking-tight prose-a:text-blue-700 prose-img:rounded-md prose-img:shadow-lg mt-8"
    >
      <h1
        class="text-xl sm:text-3xl font-bold leading-tight tracking-tight my-4"
      >
        {entry.data.title}
      </h1>
      <p class="text-slate-500">
        {formatDateMedium(entry.data.date)}
      </p>


      <div class="flex flex-wrap my-4">
        {
          entry.data.tags.map((tag: any) => (
            <a 
              href={`/writing?tag=${encodeURIComponent(tag)}`}
              class="text-sm font-semibold text-slate-700 mr-2 bg-slate-200 px-2 py-1 rounded-md hover:bg-slate-300 transition-colors"
            >
              {tag}
            </a>
          ))
        }
      </div>

      <Content components={{ Sidenote }}/>
    </div>

    <div class="comment giscus mt-8"></div>
  </article>
  <script>
    document.querySelectorAll('pre').forEach((pre) => {
      const wrapper = document.createElement('div');
      wrapper.style.cssText = 'position:relative';
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement('button');
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
      btn.title = 'Copy code';
      btn.style.cssText = 'position:absolute;top:0.5rem;right:0.5rem;padding:0.3rem;background:transparent;border:none;cursor:pointer;color:#94a3b8;border-radius:4px;display:flex;align-items:center;transition:color 0.15s';

      btn.addEventListener('mouseenter', () => btn.style.color = '#475569');
      btn.addEventListener('mouseleave', () => {
        if (!btn.dataset.copied) btn.style.color = '#94a3b8';
      });

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code')?.innerText ?? pre.innerText;
        await navigator.clipboard.writeText(code);
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        btn.style.color = '#16a34a';
        btn.dataset.copied = 'true';
        setTimeout(() => {
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          btn.style.color = '#94a3b8';
          delete btn.dataset.copied;
        }, 2000);
      });

      wrapper.appendChild(btn);
    });
  </script>
  <script
    src="https://giscus.app/client.js"
    data-repo="Shubham-Rasal/portfolio2"
    data-repo-id="R_kgDOJuFwsQ"
    data-category="General"
    data-category-id="DIC_kwDOJuFwsc4Ce1nf"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="1"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang="en"
    crossorigin="anonymous"
    async></script>
</Layout>
