---
import Layout from "../layouts/Layout.astro";
import projects from "../content/projects/projects.json";
import { Github, GithubIcon } from "lucide-react";

/** @type {{[key: string]: any[]}} */
let categories = Object.create(null);
for (let i = 0; i < projects.length; i++) {
  const project = projects[i];
  const cat = project.category && project.category.trim() ? project.category : 'Uncategorized';
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(project);
}
---

<Layout title="Projects">
  <main class="flex flex-col items-center justify-center w-full flex-1 px-4 pt-20 text-left">
    <div class="flex flex-col w-full max-w-3xl">
      <h1 class="text-3xl font-bold mb-2" style="color: var(--lw-text)">Projects</h1>
      <p class="text-sm mb-10" style="color: var(--lw-muted)">
        A selection of recent builds and experiments.
      </p>
      {Object.entries(categories).map(([cat, projs]) => {
        const arr = projs;
        return (
          (arr && (arr as any[]).length > 0) && (
            <section class="w-full mb-10">
              <h2 class="text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--lw-muted)">
                {cat || "Other"}
              </h2>
              <ul class="space-y-4 text-sm">
                {(arr as any[]).map((project) => (
                  <li class="border-b pb-3 last:border-b-0 last:pb-0" style="border-color: var(--lw-border)">
                    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                      {project.live || project.github ? (
                        <a
                          href={project.live ? project.live : project.github}
                          class="text-base font-semibold hover:underline"
                          style="color: var(--lw-text)"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {project.title}
                        </a>
                      ) : (
                        <span class="text-base font-semibold" style="color: var(--lw-text)">{project.title}</span>
                      )}
                      <div class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.15em]" style="color: var(--lw-muted)">
                        {project.live && (
                          <a href={project.live} class="hover:underline" style="color: var(--lw-link)" target="_blank" rel="noopener noreferrer">
                            Live
                          </a>
                        )}
                        {project.github && (
                          <a href={project.github} class="hover:underline" style="color: var(--lw-link)" target="_blank" rel="noopener noreferrer">
                            GitHub
                          </a>
                        )}
                      </div>
                    </div>
                    <p class="mt-1 text-sm" style="color: var(--lw-muted)">{project.description}</p>
                  </li>
                ))}
              </ul>
            </section>
          )
        );
      })}
    </div>
  </main>
</Layout>
