---
import { MdEmail } from "react-icons/md";
import Layout from "../layouts/Layout.astro";
import { Github, Twitter } from "lucide-react";

const recentProjects = [
  {
    title: "sam",
    description:
      "An AI-native video editor that works with your claude code, opencode, codex, etc to edit videos by prompting",
    github: "https://sam.shubhamrasal.com",
  },
  {
    title: "open-conductor",
    description: "A desktop app that lets you run and manage multiple local AI coding agents side by side.",
    github: "https://github.com/Shubham-Rasal/open-conductor",
  },
] as const;
---

<style>
  html, body {
    overflow: hidden;
    height: 100%;
  }
  :global(.dark) .tree-bg {
    opacity: 0.05 !important;
  }
</style>

<Layout title="About">
  <main class="flex flex-col items-center justify-start w-full h-screen overflow-hidden p-2 pt-8 text-center relative">
    <img src="/tree-bg.png" alt="" class="tree-bg" aria-hidden="true" style="position: fixed; width: 120%; max-width: none; bottom: -25%; right: -15%; top: auto; left: auto; opacity: 0.1; pointer-events: none; z-index: 0;" />
    <div class="flex flex-col items-center w-full max-w-2xl" style="position: relative; z-index: 1;">
      <h1 class="text-3xl font-bold mb-8" style="color: var(--lw-text)">Shubham Rasal</h1>
      <section class="w-full text-left mb-8 space-y-2" style="color: var(--lw-text)">
        <ul class="list-disc ml-6 text-base space-y-2">
          <li>currently SWE @ <span class="font-semibold text-emerald-600 dark:text-emerald-400">Oracle</span>
            <li>it @ <span class="font-semibold text-amber-600 dark:text-amber-400">NITK</span></li>
          <li>prev: SWE intern @ <span class="font-semibold text-emerald-600 dark:text-emerald-400">Oracle</span>
              — Built a workflow visualisation engine (FlowGenie) for the SRE team, moved UI to React, made things smoother for everyone.</li>
          <li class="italic">recently:</li>
          <ul class="ml-6 list-[circle] text-md space-y-2">
            {recentProjects.map((project) => (
              <li>
                <a
                  href={project.github}
                  class="font-semibold hover:underline"
                  style="color: var(--lw-link)"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {project.title}
                </a>
                <span style="color: var(--lw-muted)"> — {project.description}</span>
              </li>
            ))}
          </ul>
          <li>prev: Back End Developer @ <span class="font-semibold text-emerald-600 dark:text-emerald-400">Shortsqueeze</span> — Built APIs, auth, and a doc parser in Go. Made things fast with concurrency.</li>
          <li class="italic">
            my core values
            <ul class="ml-6 mt-2 list-[circle] text-md not-italic space-y-2">
              <li>high agency and a maniacal sense of urgency</li>
            </ul>
          </li>
        </ul>
      </section>
      <div class="flex flex-row w-full justify-start gap-4 mb-8">
        <a href="mailto:bluequbits@gmail.com" class="hover:scale-110 transition" style="color: var(--lw-link)">
          <MdEmail className="h-6 w-6" />
        </a>
        <a href="https://github.com/Shubham-Rasal" class="hover:scale-110 transition" style="color: var(--lw-link)">
          <Github className="h-6 w-6" />
        </a>
        <a href="https://x.com/bluequbit" class="hover:scale-110 transition" style="color: var(--lw-link)">
          <Twitter className="h-6 w-6" />
        </a>
      </div>
      <div class="w-full">
        <a href="/projects" class="hover:underline" style="color: var(--lw-muted)">see what i've built →</a>  or
        <a href="/writing" class="hover:underline" style="color: var(--lw-muted)">read my writing →</a>
      </div>
     
      
    </div>
  </main>
</Layout>

