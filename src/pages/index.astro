---
import { MdEmail } from "react-icons/md";
import Layout from "../layouts/Layout.astro";
import { Github, Twitter } from "lucide-react";
import { getCollection } from "astro:content";

interface BlogPost {
  slug?: string;
  id?: string;
  data: {
    title: string;
    date: Date;
    description?: string;
  };
}

// Fetch top 2 blog posts
const allBlogPosts: BlogPost[] = await getCollection("blog");
allBlogPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const topBlogPosts: BlogPost[] = allBlogPosts.slice(0, 2);
---

<Layout title="About">
  <main class="flex flex-col items-center justify-center w-full flex-1 p-2 pt-20 text-center">
    <div class="flex flex-col items-center w-full max-w-2xl">
      <h1 class="text-3xl font-bold mb-8">Shubham Rasal</h1>
      <section class="w-full text-left mb-8 space-y-2">
        <ul class="list-disc ml-6 text-base space-y-2">
          <li>currently SWE @ <span class="font-semibold text-green-400">Oracle</span> 
            <li>it @ <span class="font-semibold text-yellow-300">NITK</span></li>
          <li>prev: SWE intern @ <span class="font-semibold text-green-400">Oracle</span> 
             — Built a workflow visualisation engine (FlowGenie) for the SRE team, moved UI to React, made things smoother for everyone.</li>
          <li class="italic">recently:</li>
          <ul class="ml-6 list-[circle] text-md space-y-2">
            <li>working on <span class="text-yellow-500 font-semibold">
              <a href="https://settle.capital/" class="text-yellow-500 font-semibold">
                settle
              </a>
              </span> , a USDC payment settlement system</li>
            <li>built multiple <span class="text-yellow-500 font-semibold">ai agentic systems</span> for multiple hackathons</li>
            <li>won <span class="text-yellow-500 font-semibold">
              <a href="https://www.encode.club/ai-blueprints" class="text-yellow-500 font-semibold">
                AI Blueprints
              </a>
             </span> hackathon for building <a href="https://github.com/Shubham-Rasal/Agent-Nexus-Protocol" class="text-yellow-500 font-semibold">an ai agent collaboration framework</a></li>
