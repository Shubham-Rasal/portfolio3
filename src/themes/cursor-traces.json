{
  "name": "cursor-traces",
  "type": "dark",
  "colors": {
    "editor.background": "#18182a",
    "editor.foreground": "#dbd5c0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#575770",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#c9a660" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": { "foreground": "#c87a50" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#6b90d4" }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": { "foreground": "#6dc98a" }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.type.property-name",
        "meta.object-literal.key",
        "variable.other.property"
      ],
      "settings": { "foreground": "#6b90d4" }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#dbd5c0" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#c9a660" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#8888a8" }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": { "foreground": "#6dc98a" }
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": { "foreground": "#c87a50" }
    },
    {
      "scope": ["support.type", "support.class.builtin"],
      "settings": { "foreground": "#6dc98a" }
    },
    {
      "scope": ["keyword.operator.logical", "keyword.operator.comparison"],
      "settings": { "foreground": "#6b90d4" }
    }
  ]
}
